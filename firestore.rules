rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if user is authenticated
    function isAuth() {
      return request.auth != null;
    }
    
    // Check if user owns the document
    function isMine(userId) {
      return isAuth() && request.auth.uid == userId;
    }
    
    // FLICKS (Photos)
    match /flicks/{flickId} {
      // Anyone logged in can read (filtering done in app)
      allow read: if isAuth();
      
      // Only owner can create
      allow create: if isAuth() && isMine(request.resource.data.userId);
      
      // Owner can update anything, others can only update reactions or commentCount
      allow update: if isAuth() && (
        isMine(resource.data.userId) || 
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['reactions', 'reactionCount', 'updatedAt']) ||
        // Allow anyone to increment/decrement commentCount
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['commentCount'])
      );
      
      // Only owner can delete
      allow delete: if isAuth() && isMine(resource.data.userId);
    }
    
    // USERS
    match /users/{userId} {
      allow read: if true;  // Allow anyone to read user profiles (needed for app startup)

      // Owner can always write their own profile.
      // Cross-user writes are limited strictly to social relationship fields used by friend requests.
      allow write: if isAuth() && (
        isMine(userId) ||
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly([
            'pendingFollowRequests',
            'sentFollowRequests',
            'following',
            'followers',
            'blockedUsers'
          ])
      );

      // Legacy friend groups (kept for backwards compatibility reads/migrations)
      match /friendGroups/{groupId} {
        allow read, create, update, delete: if isMine(userId);
      }
    }

    // SHARED GROUPS (MVP social groups)
    match /groups/{groupId} {
      allow read: if isAuth() && request.auth.uid in resource.data.memberIds;

      // Any authenticated user can create a group they own
      allow create: if isAuth() && request.resource.data.ownerId == request.auth.uid;

      // Only admins can update core group fields
      allow update: if isAuth() && (
        request.auth.uid in resource.data.adminIds ||
        request.auth.uid == resource.data.ownerId
      );

      // Only owner can delete group
      allow delete: if isAuth() && request.auth.uid == resource.data.ownerId;

      // Members subcollection
      match /members/{memberId} {
        allow read: if isAuth() &&
          request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberIds;

        allow create, update: if isAuth() && (
          // Admin can manage membership
          request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.adminIds ||
          request.auth.uid == get(/databases/$(database)/documents/groups/$(groupId)).data.ownerId ||
          // User can create/update their own member doc when accepting invite
          request.auth.uid == memberId
        );

        allow delete: if isAuth() && (
          request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.adminIds ||
          request.auth.uid == get(/databases/$(database)/documents/groups/$(groupId)).data.ownerId ||
          request.auth.uid == memberId
        );
      }

      // Invites subcollection
      match /invites/{inviteId} {
        allow read: if isAuth() && (
          request.auth.uid == resource.data.inviteeId ||
          request.auth.uid == resource.data.inviterId ||
          request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.adminIds ||
          request.auth.uid == get(/databases/$(database)/documents/groups/$(groupId)).data.ownerId
        );

        // Admin/owner can create invites
        allow create: if isAuth() && (
          request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.adminIds ||
          request.auth.uid == get(/databases/$(database)/documents/groups/$(groupId)).data.ownerId
        );

        // Invitee can respond, admin/owner can manage
        allow update: if isAuth() && (
          request.auth.uid == resource.data.inviteeId ||
          request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.adminIds ||
          request.auth.uid == get(/databases/$(database)/documents/groups/$(groupId)).data.ownerId
        );

        allow delete: if isAuth() && (
          request.auth.uid == resource.data.inviterId ||
          request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.adminIds ||
          request.auth.uid == get(/databases/$(database)/documents/groups/$(groupId)).data.ownerId
        );
      }
    }
    
    // FRIENDSHIPS
    match /friendships/{friendshipId} {
      allow read, write: if isAuth();
    }
    
    // FRIEND REQUESTS
    match /friendRequests/{requestId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isAuth();
    }
    
    // COMMENTS
    match /comments/{commentId} {
      allow read: if isAuth();
      allow create: if isAuth();
      // Owner can update anything, others can only update reactions field
      allow update: if isAuth() && (
        isMine(resource.data.userId) || 
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['reactions'])
      );
      // Allow delete if user owns the comment (check both resource.data and request.auth)
      allow delete: if isAuth() && (
        resource.data.userId == request.auth.uid ||
        // Fallback: if userId field missing, allow any auth user (app-level check protects)
        !resource.data.keys().hasAny(['userId'])
      );
    }
    
    // REPLIES
    match /replies/{replyId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth() && isMine(resource.data.userId);
      allow delete: if isAuth() && (
        isMine(resource.data.userId) || 
        isMine(resource.data.flickOwnerId)
      );
    }
    
    // NOTIFICATIONS - Fixed to allow creating notifications for others
    match /notifications/{notificationId} {
      // Users can read their own notifications
      allow read: if isAuth() && isMine(resource.data.userId);
      
      // Any authenticated user can CREATE notifications (for messaging, likes, etc.)
      // The app controls who receives what notifications
      allow create: if isAuth();
      
      // Only the owner can update (mark as read) or delete
      allow update, delete: if isAuth() && isMine(resource.data.userId);
    }

    // FEEDBACK submissions from Contact Us
    match /feedback/{feedbackId} {
      // User can create feedback only for themselves
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      // User can read only their own feedback entries
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      // No client-side updates/deletes (handled by admin tools)
      allow update, delete: if false;
    }

    // REPORTS (photo/user reports)
    match /reports/{reportId} {
      // Reporter must be authenticated and match reporterId field
      allow create: if isAuth() && request.resource.data.reporterId == request.auth.uid;
      // Users can read only their own reports
      allow read: if isAuth() && resource.data.reporterId == request.auth.uid;
      allow update, delete: if false;
    }
    
    // CHAT SESSIONS - Fixed collection name and rules
    match /chatSessions/{chatId} {
      // Allow read if user is a participant
      allow read: if isAuth() && 
        request.auth.uid in resource.data.participants;
      
      // Allow create if user is adding themselves as participant
      allow create: if isAuth() && 
        request.auth.uid in request.resource.data.participants;
      
      // Allow update if user is a participant (for updating lastMessage, etc.)
      allow update: if isAuth() && 
        request.auth.uid in resource.data.participants;
      
      // Only participants can delete
      allow delete: if isAuth() && 
        request.auth.uid in resource.data.participants;
      
      // MESSAGES subcollection - FIXED RULES
      match /messages/{messageId} {
        // Check if user is participant in parent chat
        function isChatParticipant() {
          return request.auth.uid in get(/databases/$(database)/documents/chatSessions/$(chatId)).data.participants;
        }
        
        // Participants can read messages
        allow read: if isAuth() && isChatParticipant();
        
        // Participants can create messages (must match senderId)
        allow create: if isAuth() && 
          isChatParticipant() && 
          request.auth.uid == request.resource.data.senderId;
        
        // Sender can update their own messages OR participants can update constrained delivery/reaction/backfill fields
        allow update: if isAuth() && isChatParticipant() && (
          // Sender can update anything
          request.auth.uid == resource.data.senderId ||
          // Recipient can only update read/delivered fields (delivery receipts)
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read', 'delivered']) ||
          // Participants can backfill canonical flickId for legacy chat-photo messages
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['flickId']) ||
          // Anyone can add reactions (reactions field or reactions.{userId} field)
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions']) ||
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions', 'reactions.' + request.auth.uid])
        );
        
        // Sender can delete their own messages
        allow delete: if isAuth() && 
          isChatParticipant() && 
          request.auth.uid == resource.data.senderId;
      }
    }
  }
}
