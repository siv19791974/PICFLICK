rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.admin == true || 
         request.auth.uid in ['ADMIN_UID_1', 'ADMIN_UID_2']);
    }

    function isValidUserData() {
      return request.resource.data.keys().hasAll(['uid', 'email', 'displayName']) &&
             request.resource.data.uid is string &&
             request.resource.data.uid.size() > 0;
    }

    function isValidFlickData() {
      return request.resource.data.keys().hasAll(['id', 'userId', 'imageUrl', 'timestamp']) &&
             request.resource.data.userId is string &&
             request.resource.data.imageUrl is string;
    }

    function isFriendOf(ownerId) {
      return isAuthenticated() && 
        ownerId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.following &&
        request.auth.uid in get(/databases/$(database)/documents/users/$(ownerId)).data.following;
    }

    function isNotBlockedBy(ownerId) {
      return isAuthenticated() && 
        !(request.auth.uid in get(/databases/$(database)/documents/users/$(ownerId)).data.blockedUsers);
    }

    // ==================== USERS COLLECTION ====================
    match /users/{userId} {
      // Allow read if: authenticated and not blocked
      allow read: if isAuthenticated() && isNotBlockedBy(userId);
      
      // Allow create: only own profile
      allow create: if isOwner(userId) && isValidUserData();
      
      // Allow update: only own profile, can't change uid, can only update own fields
      allow update: if isOwner(userId) && 
        request.resource.data.uid == resource.data.uid;
      
      // Allow delete: only owner
      allow delete: if isOwner(userId);
    }

    // ==================== FLICKS (PHOTOS) COLLECTION ====================
    match /flicks/{flickId} {
      // Allow read if: 
      // - Public flick, or
      // - Owner viewing, or
      // - Friend viewing (mutual following), or
      // - Admin
      allow read: if isAuthenticated() && (
        resource.data.privacy == 'public' ||
        isOwner(resource.data.userId) ||
        isAdmin() ||
        (isFriendOf(resource.data.userId) && isNotBlockedBy(resource.data.userId))
      );
      
      // Allow create: authenticated users with valid data
      allow create: if isAuthenticated() && 
        isValidFlickData() && 
        isOwner(request.resource.data.userId);
      
      // Allow update: only owner can update their flicks
      allow update: if isAuthenticated() && 
        isOwner(resource.data.userId) &&
        request.resource.data.userId == resource.data.userId;
      
      // Allow delete: owner or admin
      allow delete: if isAuthenticated() && 
        (isOwner(resource.data.userId) || isAdmin());
    }

    // ==================== CHAT SESSIONS ====================
    match /chatSessions/{sessionId} {
      // Allow read if participant
      allow read: if isAuthenticated() && 
        request.auth.uid in resource.data.participants;
      
      // Allow create if creating for self and other user exists
      allow create: if isAuthenticated() && 
        request.auth.uid in request.resource.data.participants &&
        request.resource.data.participants.size() == 2;
      
      // Allow update: participants only (for lastMessage, lastTimestamp)
      allow update: if isAuthenticated() && 
        request.auth.uid in resource.data.participants &&
        request.auth.uid in request.resource.data.participants;
    }

    // ==================== CHAT MESSAGES ====================
    match /chatSessions/{sessionId}/messages/{messageId} {
      // Allow read if participant of parent session
      allow read: if isAuthenticated() && 
        request.auth.uid in get(/databases/$(database)/documents/chatSessions/$(sessionId)).data.participants;
      
      // Allow create if participant and sending as self
      allow create: if isAuthenticated() && 
        request.auth.uid in get(/databases/$(database)/documents/chatSessions/$(sessionId)).data.participants &&
        request.auth.uid == request.resource.data.senderId;
    }

    // ==================== REACTIONS ====================
    match /flicks/{flickId}/reactions/{userId} {
      // Allow read: anyone who can read the flick
      allow read: if isAuthenticated() && 
        get(/databases/$(database)/documents/flicks/$(flickId), {'source': 'firestore'}).data != null;
      
      // Allow create/update/delete: only for self
      allow write: if isAuthenticated() && isOwner(userId);
    }

    // ==================== COMMENTS ====================
    match /flicks/{flickId}/comments/{commentId} {
      // Allow read if can read parent flick
      allow read: if isAuthenticated() && 
        get(/databases/$(database)/documents/flicks/$(flickId), {'source': 'firestore'}).data != null;
      
      // Allow create: authenticated users with valid data
      allow create: if isAuthenticated() && 
        request.auth.uid == request.resource.data.userId &&
        request.resource.data.text is string &&
        request.resource.data.text.size() > 0;
      
      // Allow delete: owner of comment or owner of flick or admin
      allow delete: if isAuthenticated() && (
        isOwner(resource.data.userId) ||
        isOwner(get(/databases/$(database)/documents/flicks/$(flickId)).data.userId) ||
        isAdmin()
      );
    }

    // ==================== NOTIFICATIONS ====================
    match /notifications/{notificationId} {
      // Allow read: recipient only
      allow read: if isAuthenticated() && 
        request.auth.uid == resource.data.userId;
      
      // Allow create: system/backend only (Cloud Functions)
      // Users cannot create notifications directly
      allow create: if isAuthenticated() && 
        request.auth.token.system == true; // Only from Cloud Functions
      
      // Allow update: recipient only (for marking read)
      allow update: if isAuthenticated() && 
        isOwner(resource.data.userId) &&
        request.resource.data.keys().hasOnly(['isRead', 'readAt']); // Only these fields
      
      // Allow delete: recipient or admin
      allow delete: if isAuthenticated() && 
        (isOwner(resource.data.userId) || isAdmin());
    }

    // ==================== REPORTS ====================
    match /reports/{reportId} {
      // Allow read: admin only
      allow read: if isAdmin();
      
      // Allow create: authenticated users can report
      allow create: if isAuthenticated() && 
        request.auth.uid == request.resource.data.reporterId &&
        request.resource.data.keys().hasAll(['flickId', 'reporterId', 'reason', 'timestamp']);
      
      // Allow update: admin only (for resolution)
      allow update: if isAdmin();
      
      // Allow delete: admin only
      allow delete: if isAdmin();
    }

    // ==================== FEEDBACK ====================
    match /feedback/{feedbackId} {
      // Allow read: admin only
      allow read: if isAdmin();
      
      // Allow create: any authenticated user can submit feedback
      allow create: if isAuthenticated() && 
        request.auth.uid == request.resource.data.userId &&
        request.resource.data.message is string &&
        request.resource.data.message.size() > 0;
      
      // Allow update: admin only (for status updates)
      allow update: if isAdmin();
      
      // Allow delete: admin only
      allow delete: if isAdmin();
    }

    // ==================== ACHIEVEMENTS ====================
    match /achievements/{achievementId} {
      // Allow read: any authenticated user
      allow read: if isAuthenticated();
      
      // Allow create: system only (from Cloud Functions)
      allow create: if isAuthenticated() && 
        request.auth.token.system == true;
      
      // No updates or deletes
      allow update, delete: if false;
    }

    // ==================== USER ACHIEVEMENTS ====================
    match /userAchievements/{userId} {
      // Allow read: owner or admin
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      
      // Allow create/update: system only
      allow create, update: if isAuthenticated() && 
        request.auth.token.system == true;
      
      // No deletes
      allow delete: if false;
    }

    // ==================== PURCHASES (BILLING) ====================
    match /purchases/{purchaseId} {
      // Allow read: owner or admin
      allow read: if isAuthenticated() && 
        (isOwner(resource.data.userId) || isAdmin());
      
      // Allow create: system only (validated by Cloud Function)
      allow create: if isAuthenticated() && 
        request.auth.token.system == true;
      
      // No updates or deletes by users
      allow update, delete: if false;
    }

    // ==================== BLOCKED USERS ====================
    // Stored in user document, but separate collection for queries
    match /blockedUsers/{userId} {
      // Allow read: owner only
      allow read: if isOwner(userId);
      
      // Allow write: owner only
      allow write: if isOwner(userId);
    }

    // ==================== DEFAULT DENY ====================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}