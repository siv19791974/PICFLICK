rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Users collection
    match /users/{userId} {
      // Allow read if authenticated
      allow read: if isAuthenticated();
      
      // Allow create during signup
      allow create: if isOwner(userId) && 
        request.resource.data.keys().hasAll(['uid', 'email', 'displayName']) &&
        request.resource.data.uid == userId;
      
      // Allow update by owner or admin/cloud functions
      allow update: if isOwner(userId) || 
        request.auth.token.admin == true ||
        request.auth.token.service_account == true;
      
      // Subscription fields are protected - only server can modify
      // These fields can only be changed by the validatePurchase cloud function:
      // - subscriptionTier
      // - subscriptionExpiryDate
      // - purchaseToken
      // - productId
      // - subscriptionActive
    }
    
    // Flicks/Photos collection
    match /flicks/{flickId} {
      // Allow read if authenticated
      allow read: if isAuthenticated();
      
      // Allow create by authenticated users, but check storage limits
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid;
      
      // Allow update/delete by owner
      allow update, delete: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
    }
    
    // Notifications collection
    match /notifications/{notificationId} {
      // Allow read if recipient
      allow read: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
      
      // Allow create by authenticated users or cloud functions
      allow create: if isAuthenticated() || 
        request.auth.token.service_account == true;
      
      // Allow update (mark as read) by recipient
      allow update: if isAuthenticated() && 
        resource.data.userId == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['read', 'readAt']);
      
      // Allow delete by recipient
      allow delete: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
    }
    
    // Chat sessions
    match /chatSessions/{sessionId} {
      // Allow read if participant
      allow read: if isAuthenticated() && 
        request.auth.uid in resource.data.participants;
      
      // Allow create by authenticated user
      allow create: if isAuthenticated() &&
        request.auth.uid in request.resource.data.participants;
      
      // Allow update by participants
      allow update: if isAuthenticated() && 
        request.auth.uid in resource.data.participants;
    }
    
    // Chat messages
    match /chatSessions/{sessionId}/messages/{messageId} {
      // Allow read if participant in parent session
      allow read: if isAuthenticated() &&
        request.auth.uid in get(/databases/$(database)/documents/chatSessions/$(sessionId)).data.participants;
      
      // Allow create by sender
      allow create: if isAuthenticated() &&
        request.resource.data.senderId == request.auth.uid &&
        request.auth.uid in get(/databases/$(database)/documents/chatSessions/$(sessionId)).data.participants;
    }
    
    // Storage usage tracking (for monitoring)
    match /storageStats/{userId} {
      allow read: if isOwner(userId);
      allow write: if false; // Only cloud functions can write
    }
    
    // Subscription transactions log
    match /subscriptionTransactions/{transactionId} {
      // User can read their own transactions
      allow read: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
      
      // Only cloud functions can create transaction records
      allow create: if request.auth.token.service_account == true;
      
      // No updates allowed
      allow update: if false;
      allow delete: if false;
    }
  }
}
