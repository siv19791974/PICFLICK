rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if user is authenticated
    function isAuth() {
      return request.auth != null;
    }
    
    // Check if user owns the document
    function isMine(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    // Check if authenticated user is a member/admin/owner of a shared group doc
    function isGroupMember(groupId) {
      return isAuth() && (
        ('memberIds' in get(/databases/$(database)/documents/groups/$(groupId)).data &&
          request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberIds) ||
        ('friendIds' in get(/databases/$(database)/documents/groups/$(groupId)).data &&
          request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.friendIds) ||
        ('adminIds' in get(/databases/$(database)/documents/groups/$(groupId)).data &&
          request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.adminIds) ||
        ('ownerId' in get(/databases/$(database)/documents/groups/$(groupId)).data &&
          request.auth.uid == get(/databases/$(database)/documents/groups/$(groupId)).data.ownerId) ||
        ('userId' in get(/databases/$(database)/documents/groups/$(groupId)).data &&
          request.auth.uid == get(/databases/$(database)/documents/groups/$(groupId)).data.userId)
      );
    }
    
    // FLICKS (Photos)
    match /flicks/{flickId} {
      // Anyone logged in can read (filtering done in app)
      allow read: if isAuth();
      
      // Only owner can create
      allow create: if isAuth() && isMine(request.resource.data.userId);
      
      // Owner can update anything, others can only update reactions or commentCount
      allow update: if isAuth() && (
        isMine(resource.data.userId) || 
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['reactions', 'reactionCount', 'updatedAt']) ||
        // Allow anyone to increment/decrement commentCount
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['commentCount'])
      );
      
      // Only owner can delete
      allow delete: if isAuth() && isMine(resource.data.userId);
    }
    
    // USERS
    match /users/{userId} {
      allow read: if true;  // Allow anyone to read user profiles (needed for app startup)

      // Owner can always write their own profile.
      // Cross-user writes are limited strictly to social relationship fields used by friend requests.
      allow write: if isAuth() && (
        isMine(userId) ||
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly([
            'pendingFollowRequests',
            'sentFollowRequests',
            'following',
            'followers',
            'blockedUsers'
          ])
      );

      // Legacy friend groups (kept for backwards compatibility reads/migrations)
      match /friendGroups/{groupId} {
        allow read, create, update, delete: if isMine(userId);
      }
    }

    // SHARED GROUPS (MVP social groups)
    match /groups/{groupId} {
      allow read: if isAuth() && (
        ('memberIds' in resource.data && request.auth.uid in resource.data.memberIds) ||
        ('friendIds' in resource.data && request.auth.uid in resource.data.friendIds) ||
        ('adminIds' in resource.data && request.auth.uid in resource.data.adminIds) ||
        ('ownerId' in resource.data && request.auth.uid == resource.data.ownerId) ||
        ('userId' in resource.data && request.auth.uid == resource.data.userId)
      );

      // Any authenticated user can create a group they own
      allow create: if isAuth() && (
        request.resource.data.ownerId == request.auth.uid ||
        request.resource.data.userId == request.auth.uid
      );

      // Admin/owner can update core group fields.
      // Members can perform reorder-only updates (orderIndex/updatedAt).
      // Only owner can assign adminIds.
      // Legacy fallback: if older docs are missing owner/admin markers, allow existing member updates.
      allow update: if isAuth() && (
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['orderIndex', 'updatedAt']) &&
          (
            ('memberIds' in resource.data && request.auth.uid in resource.data.memberIds) ||
            ('friendIds' in resource.data && request.auth.uid in resource.data.friendIds) ||
            ('adminIds' in resource.data && request.auth.uid in resource.data.adminIds) ||
            ('ownerId' in resource.data && request.auth.uid == resource.data.ownerId) ||
            ('userId' in resource.data && request.auth.uid == resource.data.userId)
          )
        ) ||
        (
          ('adminIds' in request.resource.data && request.resource.data.adminIds != resource.data.adminIds) &&
          (
            ('ownerId' in resource.data && request.auth.uid == resource.data.ownerId) ||
            ('userId' in resource.data && request.auth.uid == resource.data.userId) ||
            (
              !('ownerId' in resource.data) &&
              !('userId' in resource.data) &&
              (
                ('memberIds' in resource.data && request.auth.uid in resource.data.memberIds) ||
                ('friendIds' in resource.data && request.auth.uid in resource.data.friendIds)
              )
            )
          )
        ) ||
        (
          (!('adminIds' in request.resource.data) || request.resource.data.adminIds == resource.data.adminIds) &&
          (
            ('adminIds' in resource.data && request.auth.uid in resource.data.adminIds) ||
            ('ownerId' in resource.data && request.auth.uid == resource.data.ownerId) ||
            ('userId' in resource.data && request.auth.uid == resource.data.userId) ||
            (
              ('memberIds' in resource.data && request.auth.uid in resource.data.memberIds) &&
              !('adminIds' in resource.data) &&
              !('ownerId' in resource.data) &&
              !('userId' in resource.data)
            ) ||
            (
              ('friendIds' in resource.data && request.auth.uid in resource.data.friendIds) &&
              !('memberIds' in resource.data) &&
              !('adminIds' in resource.data) &&
              !('ownerId' in resource.data) &&
              !('userId' in resource.data)
            )
          )
        )
      );

      // Only owner can delete group (ownerId or legacy userId).
      // Legacy fallback for migrated docs missing explicit owner fields:
      // if no ownerId/userId exists, allow a listed member to delete.
      allow delete: if isAuth() && (
        ('ownerId' in resource.data && request.auth.uid == resource.data.ownerId) ||
        ('userId' in resource.data && request.auth.uid == resource.data.userId) ||
        (
          !('ownerId' in resource.data) &&
          !('userId' in resource.data) &&
          (
            ('memberIds' in resource.data && request.auth.uid in resource.data.memberIds) ||
            ('friendIds' in resource.data && request.auth.uid in resource.data.friendIds)
          )
        )
      );

      // Members subcollection
      match /members/{memberId} {
        allow read: if isAuth() && (
          ('memberIds' in get(/databases/$(database)/documents/groups/$(groupId)).data &&
            request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberIds) ||
          ('friendIds' in get(/databases/$(database)/documents/groups/$(groupId)).data &&
            request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.friendIds) ||
          ('ownerId' in get(/databases/$(database)/documents/groups/$(groupId)).data &&
            request.auth.uid == get(/databases/$(database)/documents/groups/$(groupId)).data.ownerId) ||
          ('userId' in get(/databases/$(database)/documents/groups/$(groupId)).data &&
            request.auth.uid == get(/databases/$(database)/documents/groups/$(groupId)).data.userId)
        );

        allow create, update: if isAuth() && (
          // Admin can manage membership
          ('adminIds' in get(/databases/$(database)/documents/groups/$(groupId)).data &&
            request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.adminIds) ||
          ('ownerId' in get(/databases/$(database)/documents/groups/$(groupId)).data &&
            request.auth.uid == get(/databases/$(database)/documents/groups/$(groupId)).data.ownerId) ||
          ('userId' in get(/databases/$(database)/documents/groups/$(groupId)).data &&
            request.auth.uid == get(/databases/$(database)/documents/groups/$(groupId)).data.userId) ||
          // User can create/update their own member doc when accepting invite
          request.auth.uid == memberId
        );

        allow delete: if isAuth() && (
          ('adminIds' in get(/databases/$(database)/documents/groups/$(groupId)).data &&
            request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.adminIds) ||
          ('ownerId' in get(/databases/$(database)/documents/groups/$(groupId)).data &&
            request.auth.uid == get(/databases/$(database)/documents/groups/$(groupId)).data.ownerId) ||
          ('userId' in get(/databases/$(database)/documents/groups/$(groupId)).data &&
            request.auth.uid == get(/databases/$(database)/documents/groups/$(groupId)).data.userId) ||
          request.auth.uid == memberId
        );
      }

      // Invites subcollection
      match /invites/{inviteId} {
        allow read: if isAuth() && (
          request.auth.uid == resource.data.inviteeId ||
          request.auth.uid == resource.data.inviterId ||
          ('adminIds' in get(/databases/$(database)/documents/groups/$(groupId)).data &&
            request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.adminIds) ||
          ('ownerId' in get(/databases/$(database)/documents/groups/$(groupId)).data &&
            request.auth.uid == get(/databases/$(database)/documents/groups/$(groupId)).data.ownerId) ||
          ('userId' in get(/databases/$(database)/documents/groups/$(groupId)).data &&
            request.auth.uid == get(/databases/$(database)/documents/groups/$(groupId)).data.userId)
        );

        // Admin/owner can create invites
        allow create: if isAuth() && (
          ('adminIds' in get(/databases/$(database)/documents/groups/$(groupId)).data &&
            request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.adminIds) ||
          ('ownerId' in get(/databases/$(database)/documents/groups/$(groupId)).data &&
            request.auth.uid == get(/databases/$(database)/documents/groups/$(groupId)).data.ownerId) ||
          ('userId' in get(/databases/$(database)/documents/groups/$(groupId)).data &&
            request.auth.uid == get(/databases/$(database)/documents/groups/$(groupId)).data.userId)
        );

        // Invitee can respond, admin/owner can manage
        allow update: if isAuth() && (
          request.auth.uid == resource.data.inviteeId ||
          ('adminIds' in get(/databases/$(database)/documents/groups/$(groupId)).data &&
            request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.adminIds) ||
          ('ownerId' in get(/databases/$(database)/documents/groups/$(groupId)).data &&
            request.auth.uid == get(/databases/$(database)/documents/groups/$(groupId)).data.ownerId) ||
          ('userId' in get(/databases/$(database)/documents/groups/$(groupId)).data &&
            request.auth.uid == get(/databases/$(database)/documents/groups/$(groupId)).data.userId)
        );

        allow delete: if isAuth() && (
          request.auth.uid == resource.data.inviterId ||
          ('adminIds' in get(/databases/$(database)/documents/groups/$(groupId)).data &&
            request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.adminIds) ||
          ('ownerId' in get(/databases/$(database)/documents/groups/$(groupId)).data &&
            request.auth.uid == get(/databases/$(database)/documents/groups/$(groupId)).data.ownerId) ||
          ('userId' in get(/databases/$(database)/documents/groups/$(groupId)).data &&
            request.auth.uid == get(/databases/$(database)/documents/groups/$(groupId)).data.userId)
        );
      }
    }
    
    // FRIENDSHIPS
    match /friendships/{friendshipId} {
      allow read, write: if isAuth();
    }
    
    // FRIEND REQUESTS
    match /friendRequests/{requestId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isAuth();
    }
    
    // COMMENTS
    match /comments/{commentId} {
      allow read: if isAuth();
      allow create: if isAuth();
      // Owner can update anything, others can only update reactions field
      allow update: if isAuth() && (
        isMine(resource.data.userId) || 
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['reactions'])
      );
      // Allow delete if user owns the comment (check both resource.data and request.auth)
      allow delete: if isAuth() && (
        resource.data.userId == request.auth.uid ||
        // Fallback: if userId field missing, allow any auth user (app-level check protects)
        !resource.data.keys().hasAny(['userId'])
      );
    }
    
    // REPLIES
    match /replies/{replyId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth() && isMine(resource.data.userId);
      allow delete: if isAuth() && (
        isMine(resource.data.userId) || 
        isMine(resource.data.flickOwnerId)
      );
    }
    
    // NOTIFICATIONS - Fixed to allow creating notifications for others
    match /notifications/{notificationId} {
      // Users can read their own notifications
      allow read: if isAuth() && isMine(resource.data.userId);
      
      // Any authenticated user can CREATE notifications (for messaging, likes, etc.)
      // The app controls who receives what notifications
      allow create: if isAuth();
      
      // Only the owner can update (mark as read) or delete
      allow update, delete: if isAuth() && isMine(resource.data.userId);
    }

    // FEEDBACK submissions from Contact Us
    match /feedback/{feedbackId} {
      // User can create feedback only for themselves
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      // User can read only their own feedback entries
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      // No client-side updates/deletes (handled by admin tools)
      allow update, delete: if false;
    }

    // REPORTS (photo/user reports)
    match /reports/{reportId} {
      // Reporter must be authenticated and match reporterId field
      allow create: if isAuth() && request.resource.data.reporterId == request.auth.uid;
      // Users can read only their own reports
      allow read: if isAuth() && resource.data.reporterId == request.auth.uid;
      allow update, delete: if false;
    }
    
    // CHAT SESSIONS - Fixed collection name and rules
    match /chatSessions/{chatId} {
      function isGroupChat() {
        return ('isGroup' in resource.data && resource.data.isGroup == true) ||
               ('isGroup' in request.resource.data && request.resource.data.isGroup == true);
      }

      function groupIdFromSession() {
        return resource.data.groupId;
      }

      function groupIdFromCreate() {
        return request.resource.data.groupId;
      }

      function isChatParticipant() {
        return isAuth() && request.auth.uid in resource.data.participants;
      }

      function canAccessGroupChatByMembership() {
        return isAuth() &&
          isGroupChat() &&
          ((groupIdFromSession() is string && isGroupMember(groupIdFromSession())) ||
           (groupIdFromCreate() is string && isGroupMember(groupIdFromCreate())));
      }

      // Read if participant OR if this is a group chat and user is valid group member
      allow read: if isChatParticipant() || canAccessGroupChatByMembership();
      
      // Create if user adds self as participant OR group membership allows opening/creating group session
      allow create: if isAuth() && (
        request.auth.uid in request.resource.data.participants ||
        (('isGroup' in request.resource.data && request.resource.data.isGroup == true) &&
          ('groupId' in request.resource.data) &&
          request.resource.data.groupId is string &&
          isGroupMember(request.resource.data.groupId))
      );
      
      // Update if participant OR if group member on group chat
      allow update: if isChatParticipant() || canAccessGroupChatByMembership();
      
      // Delete only participants
      allow delete: if isChatParticipant();
      
      // MESSAGES subcollection - FIXED RULES
      match /messages/{messageId} {
        // Check if user is participant in parent chat or group member for group sessions
        function canAccessParentChat() {
          return isAuth() && (
            request.auth.uid in get(/databases/$(database)/documents/chatSessions/$(chatId)).data.participants ||
            (
              ('isGroup' in get(/databases/$(database)/documents/chatSessions/$(chatId)).data &&
                get(/databases/$(database)/documents/chatSessions/$(chatId)).data.isGroup == true) &&
              ('groupId' in get(/databases/$(database)/documents/chatSessions/$(chatId)).data) &&
              get(/databases/$(database)/documents/chatSessions/$(chatId)).data.groupId is string &&
              isGroupMember(get(/databases/$(database)/documents/chatSessions/$(chatId)).data.groupId)
            )
          );
        }
        
        // Participants/group-members can read messages
        allow read: if canAccessParentChat();
        
        // Participants/group-members can create messages (must match senderId)
        allow create: if canAccessParentChat() && 
          request.auth.uid == request.resource.data.senderId;
        
        // Sender can update their own messages OR participants/group-members can update constrained delivery/reaction/backfill fields
        allow update: if canAccessParentChat() && (
          // Sender can update anything
          request.auth.uid == resource.data.senderId ||
          // Recipient can only update read/delivered fields (delivery receipts)
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read', 'delivered']) ||
          // Participants can backfill canonical flickId for legacy chat-photo messages
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['flickId']) ||
          // Anyone can add reactions (reactions field or reactions.{userId} field)
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions']) ||
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions', 'reactions.' + request.auth.uid])
        );
        
        // Sender can delete their own messages
        allow delete: if canAccessParentChat() && 
          request.auth.uid == resource.data.senderId;
      }
    }
  }
}
