rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Allow authenticated users to read and write their own chat images
    match /chat_images/{chatId}/{imageId} {
      allow read, write: if request.auth != null;
    }
    
    // Allow authenticated users to read and write photos
    match /photos/{userId}/{imageId} {
      allow read, write: if request.auth != null;
    }
    
    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}