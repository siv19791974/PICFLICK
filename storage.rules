rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Allow authenticated users to read and write their own chat images
    match /chat_images/{chatId}/{imageId} {
      allow read, write: if request.auth != null;
    }
    
    // Allow authenticated users to read photos and write their own photo files/thumbnails.
    match /photos/{userId}/{allPhotoPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}