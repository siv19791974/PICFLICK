<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Blue background matching your logo -->
    <item>
        <color android:color="#2196F3" />
    </item>
    <!-- Your actual logo.png - squeezed to fit with some padding -->
    <item
        android:width="88dp"
        android:height="88dp"
        android:left="10dp"
        android:top="10dp"
        android:right="10dp"
        android:bottom="10dp"
        android:gravity="center">
        <bitmap
            android:src="@drawable/logo"
            android:gravity="fill" />
    </item>
</layer-list>
